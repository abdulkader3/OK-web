{
  "info": {
    "name": "OK Backend API",
    "description": "Postman collection for OK Backend - Expense Tracking API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000/api",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "ledgerId",
      "value": "",
      "type": "string"
    },
    {
      "key": "paymentId",
      "value": "",
      "type": "string"
    }
  ],










  "item": [


    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register Owner",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Owner\",\n  \"email\": \"owner@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"+1234567890\",\n  \"company\": \"Acme Inc\",\n  \"role\": \"owner\"\n}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test(\"Success is true\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "});",
                  "pm.test(\"Access token exists\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.tokens.access_token).to.exist;",
                  "});",
                  "pm.test(\"Role is owner\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.user.role).to.eql('owner');",
                  "});",
                  "pm.collectionVariables.set(\"accessToken\", pm.response.json().data.tokens.access_token);",
                  "pm.collectionVariables.set(\"userId\", pm.response.json().data.user._id);"
                ]
              }
            }
          ]
        },






        
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@example.com\",\n  \"password\": \"password123\"\n}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Success is true\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "});",
                  "pm.test(\"Access token exists\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.tokens.access_token).to.exist;",
                  "});",
                  "pm.collectionVariables.set(\"accessToken\", pm.response.json().data.tokens.access_token);"
                ]
              }
            }
          ]
        }
      ]
    },






    {
      "name": "Ledgers",
      "item": [
        {
          "name": "Create Ledger (Owes Me)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/ledgers",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"owes_me\",\n  \"counterpartyName\": \"ABC Corp\",\n  \"counterpartyContact\": \"contact@abccorp.com\",\n  \"initialAmount\": 1000,\n  \"currency\": \"USD\",\n  \"dueDate\": \"2026-03-31\",\n  \"priority\": \"high\",\n  \"notes\": \"Invoice #12345\",\n  \"tags\": [\"invoice\", \"urgent\"]\n}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test(\"Success is true\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "});",
                  "pm.test(\"Ledger created with correct type\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.ledger.type).to.eql('owes_me');",
                  "});",
                  "pm.test(\"Initial amount matches\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.ledger.initialAmount).to.eql(1000);",
                  "});",
                  "pm.test(\"Outstanding balance equals initial\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.ledger.outstandingBalance).to.eql(1000);",
                  "});",
                  "pm.collectionVariables.set(\"ledgerId\", pm.response.json().data.ledger._id);"
                ]
              }
            }
          ]
        },






        {
          "name": "Get All Ledgers",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/ledgers?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["ledgers"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "limit", "value": "10"}
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Success is true\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "});",
                  "pm.test(\"Ledgers array exists\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.ledgers).to.exist;",
                  "});"
                ]
              }
            }
          ]
        },











        {
          "name": "Get Ledger by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/ledgers/{{ledgerId}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Ledger has payments array\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.recentPayments).to.exist;",
                  "});"
                ]
              }
            }
          ]
        },










        {
          "name": "Update Ledger",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/ledgers/{{ledgerId}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"priority\": \"medium\",\n  \"notes\": \"Updated notes - payment expected soon\"\n}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },









    
    {
      "name": "Payments",
      "item": [
        {
          "name": "Record Payment",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/ledgers/{{ledgerId}}/payments",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 500,\n  \"type\": \"payment\",\n  \"method\": \"bank\",\n  \"note\": \"Partial payment for invoice #12345\",\n  \"idempotencyKey\": \"payment-001-{{$randomUUID}}\"\n}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test(\"Success is true\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "});",
                  "pm.test(\"Payment amount is correct\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.payment.amount).to.eql(500);",
                  "});",
                  "pm.test(\"Previous outstanding captured\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.payment.previousOutstanding).to.eql(1000);",
                  "});",
                  "pm.test(\"New outstanding calculated correctly\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.payment.newOutstanding).to.eql(500);",
                  "});",
                  "pm.test(\"Recorded by user exists\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.payment.recordedBy).to.exist;",
                  "});",
                  "pm.test(\"Recorded at timestamp exists\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.payment.recordedAt).to.exist;",
                  "});",
                  "pm.collectionVariables.set(\"paymentId\", pm.response.json().data.payment._id);"
                ]
              }
            }
          ]
        },












        {
          "name": "Record Duplicate Payment (Idempotency Test)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/ledgers/{{ledgerId}}/payments",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 500,\n  \"type\": \"payment\",\n  \"method\": \"bank\",\n  \"note\": \"This should return the same payment\",\n  \"idempotencyKey\": \"payment-001-same-key\"\n}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Should return existing payment\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    // With same idempotency key, should return existing",
                  "    pm.expect(jsonData.data.payment._id).to.eql(pm.collectionVariables.get('paymentId'));",
                  "});"
                ]
              }
            }
          ]
        },









        {
          "name": "Get All Payments",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/payments?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["payments"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "limit", "value": "10"}
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },












    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard Summary",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/dashboard/summary",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Success is true\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "});",
                  "pm.test(\"Has totalOwedToMe\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.totalOwedToMe).to.exist;",
                  "});",
                  "pm.test(\"Has totalIOwe\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.totalIOwe).to.exist;",
                  "});",
                  "pm.test(\"Has overdueCount\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.overdueCount).to.exist;",
                  "});",
                  "pm.test(\"Has highPriorityCount\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.highPriorityCount).to.exist;",
                  "});",
                  "pm.test(\"Has recentLedgers array\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.recentLedgers).to.exist;",
                  "});",
                  "pm.test(\"Has dueLedgers array\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.dueLedgers).to.exist;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },









    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["users"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "limit", "value": "10"}
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Users array exists\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.users).to.exist;",
                  "});"
                ]
              }
            }
          ]
        },











        {
          "name": "Update User Permissions",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/users/{{userId}}/permissions",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"permissions\": {\n    \"canCreateLedger\": true,\n    \"canRecordPayment\": true,\n    \"canViewAllLedgers\": true\n  }\n}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Permissions updated\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.permissions.canRecordPayment).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },










    {
      "name": "Uploads",
      "item": [
        {
          "name": "Upload Receipt",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/uploads/receipt",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "REPLACE_WITH_ACTUAL_FILE_PATH",
                  "description": "Click here to select a file from your computer"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test(\"Returns Cloudinary URL\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.url).to.include('cloudinary');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },












    {
      "name": "Audit",
      "item": [
        {
          "name": "Get Audit Logs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/audit/{{ledgerId}}?collection=ledgers",
              "host": ["{{baseUrl}}"],
              "path": ["audit", "{{ledgerId}}"],
              "query": [
                {"key": "collection", "value": "ledgers"}
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Logs array exists\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.logs).to.exist;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
